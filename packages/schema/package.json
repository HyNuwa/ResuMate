{
  "name": "@resumate/schema",
  "version": "1.0.0",
  "description": "Shared JSON Schema, TypeScript types, defaults and AJV validation for ResuMate",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./resume.schema.json": "./src/resume.schema.json"
  },
  "files": [
    "dist",
    "src/resume.schema.json",
    "src/sections"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
